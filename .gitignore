*.py[cod]
*$py.class
venv/
.venv/

# Docker

# OS
.DS_Store
Thumbs.db
Icon?
Icon\r

# Logs
*.log
logs/
meticulous-source/

# Testing
.pytest_cache/
.coverage
coverage.xml
coverage.json
htmlcov/
*.cover
.hypothesis/
.tox/

# Data files (runtime generated)
data/
!data/PourOverBase.json
!data/recipes/

# Update tracking
.versions.json

# Runtime markers
.rebuild-needed
.restart-requested
