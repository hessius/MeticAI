# Benchmark artifacts
benchmark_results.jsonl
*.jsonl

# Development safety marker (prevents uninstaller from deleting dev folder)
.meticai-dev

# Web app (cloned dependency)
meticai-web/

# macOS Installer build artifacts
macos-installer/build/
*.dmg
*.app
.vscode/
apps/server/data/
