{
    "name": "meticai-espresso-pro",
    "private": true,
    "version": "2.4.0-beta.1",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "kill": "fuser -k ${PORT:-5173}/tcp",
        "build": "tsc -b --noCheck && vite build",
        "build:docker": "VITE_MACHINE_MODE=proxy tsc -b --noCheck && VITE_MACHINE_MODE=proxy vite build",
        "build:machine": "VITE_MACHINE_MODE=direct tsc -b --noCheck && VITE_MACHINE_MODE=direct vite build",
        "build:ios": "VITE_MACHINE_MODE=capacitor tsc -b --noCheck && VITE_MACHINE_MODE=capacitor vite build && npx cap sync ios",
        "lint": "eslint .",
        "optimize": "vite optimize",
        "preview": "vite preview",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage",
        "test:run": "vitest run",
        "test:direct": "VITE_MACHINE_MODE=direct vitest run",
        "e2e": "playwright test",
        "e2e:ui": "playwright test --ui",
        "e2e:headed": "playwright test --headed",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "postinstall": "bash scripts/patch-capacitor-spm.sh"
    },
